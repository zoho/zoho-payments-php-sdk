{
    "name": "zohopayments/php-sdk",
    "description": "Official PHP SDK for the Zoho Payments API (IN, IN Sandbox, and US editions).",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["zoho", "payments", "sdk", "api", "payment-gateway"],
    "homepage": "https://www.zoho.com/payments/",
    "support": {
        "docs": "https://github.com/zoho/zoho-payments-php-sdk#documentation",
        "issues": "https://github.com/zoho/zoho-payments-php-sdk/issues",
        "source": "https://github.com/zoho/zoho-payments-php-sdk"
    },
    "authors": [
        {
            "name": "Zoho Payments",
            "homepage": "https://www.zoho.com/payments/"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0 || ^2.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10"
    },
    "suggest": {
        "guzzlehttp/guzzle": "A PSR-18 compatible HTTP client; install if you want to plug in Guzzle instead of the bundled cURL transport."
    },
    "autoload": {
        "psr-4": {
            "Zoho\\Payments\\": "src/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse src --level=6"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
